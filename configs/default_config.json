{
  "model": {
    "type": "cnn",
    "num_classes": 10
  },
  "data": {
    "dataset": "mnist",
    "num_clients": 10,
    "batch_size": 32
  },
  "training": {
    "rounds": 10,
    "local_epochs": 5,
    "learning_rate": 0.01,
    "client_fraction": 1.0
  },
  "privacy": {
    "enabled": false,
    "epsilon": 1.0,
    "delta": 1e-5,
    "clip_norm": 1.0
  },
  "server": {
    "host": "localhost",
    "port": 5000
  },
  "logging": {
    "level": "INFO",
    "save_metrics": true,
    "save_model": true
  }
}
