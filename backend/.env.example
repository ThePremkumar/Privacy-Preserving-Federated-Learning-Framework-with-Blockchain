# Environment Configuration for Federated Learning Healthcare Platform
# Copy this file to .env and update values for your environment

# Application Settings
APP_NAME=Federated Learning Healthcare Platform
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server Configuration
HOST=0.0.0.0
PORT=8001
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000

# Security Configuration
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/federated_healthcare
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017/federated_healthcare_logs
MONGODB_DATABASE=federated_healthcare_logs

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=100

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=http://localhost:8545
BLOCKCHAIN_CHAIN_ID=1337
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_PRIVATE_KEY=your-blockchain-private-key
BLOCKCHAIN_GAS_LIMIT=300000
BLOCKCHAIN_GAS_PRICE=20

# Federated Learning Configuration
FEDERATED_MIN_PARTICIPANTS=2
FEDERATED_MAX_PARTICIPANTS=100
FEDERATED_ROUND_TIMEOUT=3600
FEDERATED_AGGREGATION_TIMEOUT=300

# Differential Privacy Configuration
DP_EPSILON_DEFAULT=1.0
DP_DELTA_DEFAULT=0.00001
DP_MAX_PRIVACY_BUDGET=10.0
DP_NOISE_SCALE=1.0

# Model Configuration
MODEL_INPUT_DIM=100
MODEL_HIDDEN_DIM=64
MODEL_OUTPUT_DIM=10
MODEL_LEARNING_RATE=0.01
MODEL_BATCH_SIZE=32
MODEL_EPOCHS=10

# Background Tasks Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# File Storage Configuration
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=104857600
ALLOWED_FILE_TYPES=.csv,.json,.parquet

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=104857600
LOG_BACKUP_COUNT=5

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# HIPAA Compliance Configuration
AUDIT_LOG_RETENTION_DAYS=2555
DATA_ENCRYPTION_KEY=your-data-encryption-key-32-chars
ENABLE_DATA_ENCRYPTION=true
